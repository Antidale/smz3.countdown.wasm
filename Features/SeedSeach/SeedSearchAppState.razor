@using FeInfo.Common.DTOs
@using System.Runtime.CompilerServices
@using smz3.countdown.wasm.Constants
@using smz3.countdown.wasm.Models
@using smz3.countdown.wasm.Services
@inherits AppStateBase
@inject IFeApiDataService dataService

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

@code {
    private string seedsEndpoint = $"{EndpointConstants.API_BASE_ADDRESS}seed";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    public HashSet<SeedDetail> Seeds { get; private set; } = new();
    private Dictionary<int, string> SeedHtml { get; set; } = new Dictionary<int, string>();

    //TODO: add parameters to this so that the search page can call it with those
    public async Task FetchSeeds()
    {
        var seeds = await dataService.GetSeedsAsync(seedsEndpoint) ?? new List<SeedDetail>();
        foreach (var seed in seeds)
        {
            Seeds.Add(seed);
        }
    }

    public async Task<string> FetchSeedHtml(int id)
    {
        if (!Seeds.Any(x => x.SeedId == id))
        {
            var seed = await dataService.GetSeedByIdAsync(id);

            if (seed is not null)
                Seeds.Add(seed);
            else
                return string.Empty;
        }

        if (SeedHtml.ContainsKey(id))
        {
            return SeedHtml[id];
        }

        SeedHtml.TryGetValue(id, out var html);

        if (!string.IsNullOrEmpty(html))
            return html;

        html = await dataService.GetSeedHtmlAsync(id);

        if (!string.IsNullOrEmpty(html))
        {
            SeedHtml.TryAdd(id, html);
        }

        return html ?? string.Empty;
    }
}