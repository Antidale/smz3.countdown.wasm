@page "/seeds"
<PageTitle>Seed Search</PageTitle>
<SearchForm />

@if (@AppState.Seeds.Any())
{
    <SeedList />
}

@code {
    [CascadingParameter]
    public SeedSearchAppState AppState { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.Seeds.Any())
        {
            await AppState.FetchSeeds();
        }
    }
}